{
  "name": "restosur-pos-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:network": "vite --host 0.0.0.0",
    "build:desktop": "npm run build && electron-builder --win nsis",
    "start:desktop": "npm run build && electron ."
  },
  "dependencies": {
    "axios": "^1.9.0",
    "bootstrap": "^5.3.5",
    "chart.js": "^4.5.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "vite": "^5.4.19",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.restosur.pos",
    "productName": "RestoSur POS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/runtime-config.js",
        "to": "runtime-config.js"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icons/app-icon.ico",
      "artifactName": "RestoSurPOS-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
