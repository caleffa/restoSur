{
  "name": "restosur-backend",
  "version": "1.0.0",
  "description": "Backend MVC para gestión de restaurantes/cervecerías con POS, cocina, caja, stock y facturación AFIP.",
  "main": "src/server.js",
  "id": "pkgroot",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:front\"",
    "dev:api": "nodemon server.js",
    "dev:front": "npm run dev --prefix frontend",
    "start": "node src/server.js",
    "lint": "echo 'Sin linter configurado'",
    "check": "node --check src/server.js",
    "seed:operacion": "node scripts/generateOperationalData.js 60"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.7.0",
    "morgan": "^1.10.1",
    "mysql2": "^3.20.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  }
}
